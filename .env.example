# Server
PORT=8089
SESSION_SECRET=change-this-to-random-string

# Path (auto-detect jika tidak di-set)
# APP_DIR=/home/srv/cp
# APP_USER=srv

# phpMyAdmin proxy
PMA_HOST=127.0.0.1
PMA_PORT=8087

# Nginx
NGINX_PORT=80
NGINX_PREVIEW_PORT=8088

# MyControlPanel paths (override default jika perlu)
# MYCP_HOME_PREFIX=/home
# MYCP_SOCK_DIR=/run/php-fpm
# MYCP_LOG_DIR=/var/log/nginx
# MYCP_NGINX_DIR=/etc/nginx
# MYCP_PHP_CONFIG_DIR=/etc/php
# MYCP_MYSQL_SOCK=/run/mysqld/mysqld.sock
