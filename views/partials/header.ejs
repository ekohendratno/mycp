<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || 'MyControlPanel' %></title>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/monokai.min.css">
  <link rel="stylesheet" href="/assets/css/app.css">
  <link rel="icon" href="/assets/img/logo.png" type="image/png">
  <% if (typeof mycpConfig !== 'undefined') { %>
  <script>window.MyCP = <%- JSON.stringify(mycpConfig) %>;</script>
  <% } %>
</head>
<body>
  <div class="app-shell no-sidebar">
    <header class="app-header">
      <a class="brand brand-inline" href="/dashboard">
        <span class="brand-mark"><img src="/assets/img/logo.png" alt="Logo" style="height:38px;border-radius:8px"></span>
      </a>
      <nav class="top-nav" aria-label="Navigasi halaman">
        <a href="/dashboard" class="<%= activeNav === 'dashboard' ? 'active' : '' %>"><i class="fa-solid fa-gauge"></i><span>Dashboard</span></a>
        <a href="/" class="<%= activeNav === 'websites' ? 'active' : '' %>"><i class="fa-solid fa-globe"></i><span>Websites</span></a>
      </nav>
      <div class="auth-actions">
        <div class="user-dropdown">
          <button class="user-dropdown-toggle" type="button" data-dropdown-toggle>
            <i class="fa-solid fa-user"></i> <b data-auth-user>admin</b> <i class="fa-solid fa-chevron-down"></i>
          </button>
          <div class="dropdown-menu" data-dropdown-menu>
            <button type="button" data-open-change-password><i class="fa-solid fa-key"></i> Change Password</button>
            <hr>
            <button type="button" data-update-panel><i class="fa-solid fa-rotate"></i> Update Panel</button>
            <hr>
            <button type="button" data-logout><i class="fa-solid fa-right-from-bracket"></i> Logout</button>
          </div>
        </div>
      </div>
      <div class="modal-backdrop" id="changePasswordModal" aria-hidden="true">
        <div class="modal cli-root" role="dialog" aria-modal="true" style="width:min(420px,100%)">
          <div class="cli-header">
            <span class="cli-title"><i class="fa-solid fa-key"></i> Change Password</span>
            <button class="icon-btn" type="button" data-close-change-password><i class="fa-solid fa-xmark"></i></button>
          </div>
          <form id="changePasswordForm" class="create-form">
            <div class="form-grid" style="padding:16px">
              <label>Current Password
                <input type="password" name="currentPassword" required minlength="1">
              </label>
              <label>New Password
                <input type="password" name="newPassword" required minlength="8">
              </label>
              <label>Confirm New Password
                <input type="password" name="confirmPassword" required minlength="8">
              </label>
              <div id="changePasswordError" class="form-error" style="display:none;color:#dc2626;font-size:13px"></div>
              <div class="modal-actions">
                <button class="ghost-btn" type="button" data-close-change-password>Cancel</button>
                <button class="primary-btn" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </header>
    <main class="main">
